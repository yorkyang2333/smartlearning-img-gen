generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  displayName  String
  role         String   @default("STUDENT") // "TEACHER" | "STUDENT"
  isActive     Boolean  @default(true)
  teacherId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  teacher      User?    @relation("TeacherStudents", fields: [teacherId], references: [id])
  students     User[]   @relation("TeacherStudents")
  
  generations  Generation[]
  conversations Conversation[]
  modelConfigs TeacherModelConfig[]
  modelOverrides StudentModelOverride[]
  
  // Smart Learning Features Relations
  assignments       Assignment[]           @relation("TeacherAssignments")
  submissions       AssignmentSubmission[] @relation("StudentSubmissions")
  templates         PromptTemplate[]       @relation("TeacherTemplates")
  quotaConfig       QuotaConfig?           @relation("TeacherQuota")
  
  likes             GalleryLike[]          @relation("StudentLikes")
}

model Model {
  id          String   @id @default(uuid())
  name        String
  modelId     String   @unique
  type        String   // "TEXT_TO_IMAGE" | "IMAGE_TO_IMAGE" | "BOTH"
  provider    String   // "openai" | "gemini"等
  description String?
  config      String   // JSON string containing sizes, max prompt len, etc
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  
  apiEndpointId String?
  apiEndpoint   ApiEndpoint? @relation(fields: [apiEndpointId], references: [id], onDelete: SetNull)

  teacherConfigs TeacherModelConfig[]
  studentOverrides StudentModelOverride[]
  generations    Generation[]
}

model TeacherModelConfig {
  id        String  @id @default(uuid())
  teacherId String
  modelId   String
  enabled   Boolean @default(true)

  teacher   User  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  model     Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([teacherId, modelId])
}

model StudentModelOverride {
  id        String  @id @default(uuid())
  studentId String
  modelId   String
  allowed   Boolean

  student   User  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  model     Model @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([studentId, modelId])
}

model Generation {
  id             String   @id @default(uuid())
  userId         String
  modelId        String
  type           String   // "TEXT_TO_IMAGE" | "IMAGE_TO_IMAGE"
  prompt         String
  inputImageUrl  String?
  outputImageUrl String?
  size           String?
  quality        String?
  durationMs     Int?
  apiResponse    String?  // JSON string
  conversationId String?
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  model        Model         @relation(fields: [modelId], references: [id], onDelete: Restrict)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  submissions       AssignmentSubmission[]
  likes             GalleryLike[]
}

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  title     String   @default("新对话")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations Generation[]
}

model ApiEndpoint {
  id        String   @id @default(uuid())
  name      String
  baseUrl   String
  apiKey    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  models    Model[]
}

model Assignment {
  id              String   @id @default(uuid())
  teacherId       String
  title           String
  description     String
  requirements    String?  // JSON: { keywords?: string[], theme?: string, referenceImages?: string[] }
  allowedModelIds String?  // JSON: array of model IDs
  allowedSizes    String?  // JSON: array of sizes
  maxSubmissions  Int      @default(1)
  deadline        DateTime?
  type            String   @default("STANDARD") // "STANDARD" | "CHALLENGE"
  durationMin     Int?
  status          String?  // "PENDING" | "ACTIVE" | "ENDED" (for challenges)
  startedAt       DateTime?
  endedAt         DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teacher         User     @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  submissions     AssignmentSubmission[]
}

model AssignmentSubmission {
  id            String   @id @default(uuid())
  assignmentId  String
  studentId     String
  generationId  String   
  note          String?  
  status        String   @default("SUBMITTED") // SUBMITTED | REVIEWED
  feedback      String?  
  score         Int?     
  createdAt     DateTime @default(now())

  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       User       @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  generation    Generation @relation(fields: [generationId], references: [id], onDelete: Restrict)
}

model PromptTemplate {
  id          String   @id @default(uuid())
  teacherId   String
  title       String
  description String?
  template    String   
  category    String?  
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  teacher     User     @relation("TeacherTemplates", fields: [teacherId], references: [id], onDelete: Cascade)
}

model QuotaConfig {
  id           String   @id @default(uuid())
  teacherId    String   @unique
  dailyLimit   Int      @default(50)
  weeklyLimit  Int?
  blockedWords String?  // JSON array of blocked keywords
  activeHours  String?  // JSON: { start: "08:00", end: "22:00" }

  teacher      User     @relation("TeacherQuota", fields: [teacherId], references: [id], onDelete: Cascade)
}



model GalleryLike {
  id           String   @id @default(uuid())
  userId       String
  generationId String
  createdAt    DateTime @default(now())

  user         User       @relation("StudentLikes", fields: [userId], references: [id], onDelete: Cascade)
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@unique([userId, generationId])
}
